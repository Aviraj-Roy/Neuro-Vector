# MongoDB Configuration
MONGO_URI="mongodb+srv://MrYor:Aviraj%402004@neurovector.azliqcf.mongodb.net/?appName=NeuroVector"
MONGO_DB_NAME=medical_bills
MONGO_COLLECTION_NAME=bills

# =============================================================================
# Local Embedding Service Configuration (NO API CALLS)
# =============================================================================

# Local Embedding Model (sentence-transformers)
# IMPORTANT: Must be a valid Hugging Face identifier (vendor/model-name)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu

# Embedding Cache (persistent disk cache to avoid redundant computations)
EMBEDDING_CACHE_PATH=data/embedding_cache.json

# =============================================================================
# LLM Configuration - HuggingFace Inference API
# =============================================================================

# HuggingFace API Token (REQUIRED for LLM matching)
# Get your token from: https://huggingface.co/settings/tokens
# Create a token with "Read" access and paste it below
HF_API_TOKEN=

# Enable/Disable LLM Matching (set to "true" to enable)
ENABLE_LLM_MATCHING=true

# LLM Model Names (external identifiers - do NOT change)
# These map internally to HuggingFace repos:
#   phi3:mini -> microsoft/Phi-3-mini-4k-instruct
#   qwen2.5:3b -> Qwen/Qwen2.5-3B-Instruct
PRIMARY_LLM=phi3:mini
SECONDARY_LLM=qwen2.5:3b

# LLM Request Configuration
LLM_TIMEOUT=30
LLM_MIN_CONFIDENCE=0.7

# =============================================================================
# Tie-up Rate Sheets
# =============================================================================
TIEUP_DATA_DIR=data/tieups

# Semantic Matching Thresholds
CATEGORY_SIMILARITY_THRESHOLD=0.70
ITEM_SIMILARITY_THRESHOLD=0.85

# =============================================================================
# OCR Configuration (existing)
# =============================================================================
OCR_CONFIDENCE_THRESHOLD=0.6
